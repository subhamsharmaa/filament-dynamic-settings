{
    "name": "subham/filament-dynamic-settings",
    "description": "Dynamic settings plugin for Filament",
    "license": "MIT",
    "type": "library",
    "require": {
        "php": ">=8.2",
        "filament/filament": "^5.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "Subham\\FilamentDynamicSettings\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Subham\\FilamentDynamicSettings\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test-coverage": "vendor/bin/phpunit --coverage-html coverage"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Subham\\FilamentDynamicSettings\\FilamentDynamicSettingsServiceProvider"
            ]
        }
    }
}
